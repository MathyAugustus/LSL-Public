list lindex_webservices = [
    // 1. API oficial da Second Life
    "https://api.secondlife.com/datafeeds/lindex.xml",
    
    // 2. Endpoint alternativo
    "https://cap.secondlife.com/cap/0/b713fe80-283b-4585-af4d-a3b2d7c5b1d8?grid=secondlife",
    
    // 3. Cache de terceiros
    "https://lindex.secondlifegrid.net/datafeeds/lindex.xml"
