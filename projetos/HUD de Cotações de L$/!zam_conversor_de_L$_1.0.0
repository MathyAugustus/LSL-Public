// Variáveis de controle
integer current_usdbrl_index = 0;
integer current_lindex_index = 0;
key http_request_id; // ID da requisição HTTP atual
integer request_type = 0; // 0 = Lindex, 1 = USD/BRL

key dialog_user;     // Usuário atual no diálogo
integer listener_id; // ID do listener atual
integer waiting_value = FALSE; // Esperando valor do usuário
