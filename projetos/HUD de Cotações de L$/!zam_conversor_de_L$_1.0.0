// Configurações de cotação
float lindenPorDolarCompra = 247.0;    // Quantos L$ por 1 USD para COMPRA (fallback)
float lindenPorDolarVenda = 247.0;     // Quantos L$ por 1 USD para VENDA (fallback) 
float dolarParaReal = 5.43;            // cotação comercial
float dolarParaRealBcb = 5.43;         // cotação oficial BCB
float dolarParaRealPaypal = 5.43;      // PayPal: BCB - 4.5%

// Lista de webservices para USD/BRL - em ordem de prioridade
list usdbrl_webservices = [
    // 1. HG Brasil (funcionou bem nos testes)
    "https://api.hgbrasil.com/finance?format=json-cors",
    
    // 2. AwesomeAPI (tradicional)
    "https://economia.awesomeapi.com.br/json/last/USD-BRL",
    
    // 3. AwesomeAPI alternativa
    "https://economia.awesomeapi.com.br/all/USD-BRL",
    
    // 4. BCB PTAX (oficial)
    "https://olinda.bcb.gov.br/olinda/servico/PTAX/versao/v1/odata/CotacaoDolarDia(dataCotacao=@dataCotacao)?@dataCotacao='{DATA}'&$top=1&$format=json",
    
    // 5. ExchangeRate-API
    "https://api.exchangerate-api.com/v4/latest/USD",
    
    // 6. CurrencyAPI
    "https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@latest/v1/currencies/usd.json",
    
    // 7. VatComply
    "https://api.vatcomply.com/rates?base=USD",
    
    // 8. Frankfurter (Open Source)
    "https://api.frankfurter.app/latest?from=USD&to=BRL",
    
    // 9. Open Exchange Rates (free tier)
    "https://open.er-api.com/v6/latest/USD",
    
    // 10. API de Fallback - CoinGecko
    "https://api.coingecko.com/api/v3/simple/price?ids=usd&vs_currencies=brl"
