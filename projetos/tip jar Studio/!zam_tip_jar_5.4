// STUDIO59 ART's Tip Jar
// Versão: 5.7 (Fix de Persistência de Idioma e Ordenação)
// Por: Augustus Mathy

integer gIntDebug = FALSE;

// Constantes de Link Message
integer LINK_IM = 100;
integer LINK_MENU_REQ = 101;
integer LINK_MENU_RET = 102;
integer LINK_FLOAT_REQ = 103;
integer LINK_FLOAT_RET = 104;
integer LINK_LOAD_DONE = 105;
integer LINK_IDENTIFY_CMD = 106;
integer LINK_CMD_RESULT = 107;
integer LINK_RESET = 108;

// Configurações
string gStrObjectName = "STUDIO59 ART's Tip Jar";
string gStrFolderName = "Studio59_Gift";
string gStrTranslationsNc = "translations";

// Texturas
string TEXTURE_NOTE = "b1c4b8e1-1bbe-2ae6-543d-e5d13d5a0035";
string TEXTURE_STAR = "028a73a1-e4c8-4442-b6b0-ba02b2dcd025";
string TEXTURE_HEART = "d05b002a-2c8f-5e2d-8b5e-9a3c7b6e8f1a";
string TEXTURE_GLOW = "00000000-0000-0000-0000-000000000000";

// Scanner
float SCAN_RANGE = 50.0;
float SCAN_INTERVAL = 10.0;
float SCAN_ARC = PI;

// Floating text
float FADE_STEP = 0.2;
float FADE_IN_TIME = 0.6;
float FADE_OUT_TIME = 0.6;
float DISPLAY_TIME = 10.0;

// Estados do timer
integer TIMER_IDLE = 0;
integer TIMER_FADE = 1;
integer TIMER_DISPLAY = 2;
integer TIMER_MENU = 3;
integer TIMER_PARTICLES = 4;

// Variáveis Globais
key gKeyOwner;
integer gIntChannel;
integer gIntListenHandle;
integer gIntMenuActive = FALSE;
integer gIntParticleTimerActive = FALSE;
list gListParticleNotes;
integer gIntCurrentTexture = 0;
integer gIntStatusRequested = FALSE;

// Scanner
list gListNearbyAvatars;
integer gIntSensorActive = FALSE;

// Floating text
integer gIntTextState = 0;
float gFloatTextAlpha = 0.0;
string gStrCurrentMessage;
list gListCurrentLanguages;
integer gIntTextIndex = 0;
integer gIntNoAvatars = TRUE;
integer gIntTimerMode = TIMER_IDLE;
integer gIntFadeSteps;
integer gIntCurrentFadeStep;

// Controle de Carga
integer gIntTranslationsReady = FALSE;

// Mensagem padrão
string gStrDefaultEnglishMsg = "✨ STUDIO59 ART's Tip Jar ✨\nIf you enjoyed my art,\nplease help me keep it here!";

// --- FUNÇÕES DE INTERFACE ---

sendTranslatedIM(key pKeyTarget, string pStrMsgId, list pListReplacements)
{
    if (!gIntTranslationsReady)
    {
        if (pStrMsgId == "WELCOME_TIP") llInstantMessage(pKeyTarget, "Welcome! Please wait a moment while translations load...");
        return;
    }
    string pStrData = pStrMsgId;
    integer pIntIdx;
    for (pIntIdx = 0; pIntIdx < llGetListLength(pListReplacements); pIntIdx = pIntIdx + 1)
    {
        pStrData = pStrData + "|" + llList2String(pListReplacements, pIntIdx);
    }
    llMessageLinked(LINK_THIS, LINK_IM, pStrData, pKeyTarget);
}

showMenu(key pKeyUser)
{
    if (!gIntTranslationsReady)
    {
        llOwnerSay("Aguarde... as traduções ainda estão sendo carregadas.");
        return;
    }

    if (gIntMenuActive)
    {
        sendTranslatedIM(pKeyUser, "MENU_ALREADY_OPEN", []);
        return;
    }

    gIntChannel = (integer)(llFrand(-1000000000.0) - 1.0);
    gIntListenHandle = llListen(gIntChannel, "", pKeyUser, "");
    gIntMenuActive = TRUE;

    string pStrReq = "MENU_TITLE|MENU_TEST_PARTICLES|MENU_STOP_PARTICLES|MENU_CHANGE_TEXTURE|MENU_SCANNER_STATUS|MENU_HELP|MENU_CANCEL";
    llMessageLinked(LINK_THIS, LINK_MENU_REQ, pStrReq, pKeyUser);

    gIntTimerMode = TIMER_MENU;
    llSetTimerEvent(60.0);
}

cleanupMenu()
{
    if (gIntListenHandle != 0)
    {
        llListenRemove(gIntListenHandle);
        gIntListenHandle = 0;
    }
    gIntMenuActive = FALSE;
    if (gIntTimerMode == TIMER_MENU)
    {
        gIntTimerMode = TIMER_IDLE;
        llSetTimerEvent(0.0);
    }
}

// --- FUNÇÕES DE FLOATING TEXT ---

list getUniqueLanguagesFromNearby()
{
    list pUniqueLangs = [];
    integer pIntIdx;
    for (pIntIdx = 0; pIntIdx < llGetListLength(gListNearbyAvatars); pIntIdx = pIntIdx + 3)
    {
        // Normalizamos para minúsculo para evitar problemas de case do viewer
        string pStrLang = llToLower(llList2String(gListNearbyAvatars, pIntIdx + 2));
        if (llListFindList(pUniqueLangs, [pStrLang]) == -1)
        {
            pUniqueLangs = pUniqueLangs + [pStrLang];
            if (llGetListLength(pUniqueLangs) >= 10) jump break_loop;
        }
    }
    @break_loop;
    return llListSort(pUniqueLangs, 1, TRUE); // Ordenação alfabética para estabilidade
}

startFadeIn(string pStrMessage)
{
    gIntTextState = 1;
    gFloatTextAlpha = 0.0;
    gStrCurrentMessage = pStrMessage;
    gIntFadeSteps = (integer)(FADE_IN_TIME / FADE_STEP);
    if (gIntFadeSteps < 1) gIntFadeSteps = 1;
    gIntCurrentFadeStep = 0;
    llSetText(gStrCurrentMessage, <1.0, 1.0, 1.0>, 0.0);
    gIntTimerMode = TIMER_FADE;
    llSetTimerEvent(FADE_STEP);
}

startFadeOut()
{
    gIntTextState = 3;
    gIntFadeSteps = (integer)(FADE_OUT_TIME / FADE_STEP);
    if (gIntFadeSteps < 1) gIntFadeSteps = 1;
    gIntCurrentFadeStep = 0;
    gIntTimerMode = TIMER_FADE;
    llSetTimerEvent(FADE_STEP);
}

advanceToNextMessage()
{
    if (!gIntTranslationsReady) return;

    integer pIntLangCount = llGetListLength(gListCurrentLanguages);
    if (pIntLangCount == 0)
    {
        gIntNoAvatars = TRUE;
        gIntTextState = 0;
        llSetText(gStrDefaultEnglishMsg, <1.0, 1.0, 1.0>, 1.0);
        return;
    }

    gIntTextIndex = gIntTextIndex + 1;
    if (gIntTextIndex >= pIntLangCount) gIntTextIndex = 0;

    string pStrLang = llList2String(gListCurrentLanguages, gIntTextIndex);
    llMessageLinked(LINK_THIS, LINK_FLOAT_REQ, pStrLang + "|FLOATING_WELCOME", NULL_KEY);
}

updateFade()
{
    if (gIntTextState == 1)
    {
        gIntCurrentFadeStep = gIntCurrentFadeStep + 1;
        gFloatTextAlpha = (float)gIntCurrentFadeStep / (float)gIntFadeSteps;
        if (gIntCurrentFadeStep >= gIntFadeSteps)
        {
            gFloatTextAlpha = 1.0;
            llSetText(gStrCurrentMessage, <1.0, 1.0, 1.0>, 1.0);
            gIntTextState = 2;
            gIntTimerMode = TIMER_DISPLAY;
            llSetTimerEvent(DISPLAY_TIME);
        }
        else
        {
            llSetText(gStrCurrentMessage, <1.0, 1.0, 1.0>, gFloatTextAlpha);
        }
    }
    else if (gIntTextState == 3)
    {
        gIntCurrentFadeStep = gIntCurrentFadeStep + 1;
        gFloatTextAlpha = 1.0 - ((float)gIntCurrentFadeStep / (float)gIntFadeSteps);
        if (gIntCurrentFadeStep >= gIntFadeSteps)
        {
            gFloatTextAlpha = 0.0;
            llSetText("", <1.0, 1.0, 1.0>, 0.0);
            advanceToNextMessage();
        }
        else
        {
            llSetText(gStrCurrentMessage, <1.0, 1.0, 1.0>, gFloatTextAlpha);
        }
    }
}

refreshFloatingText()
{
    list pNewLangs = getUniqueLanguagesFromNearby();
    string pStrNew = llDumpList2String(pNewLangs, ",");
    string pStrOld = llDumpList2String(gListCurrentLanguages, ",");

    // Força atualização se houver qualquer mudança na lista de idiomas ou se estava sem avatares
    if (pStrNew != pStrOld || gIntNoAvatars)
    {
        gListCurrentLanguages = pNewLangs;
        gIntTextIndex = -1;
        gIntNoAvatars = FALSE;
        advanceToNextMessage();
    }
}

// --- FUNÇÕES DE PARTÍCULAS ---

initParticleSystem(string pStrTexture)
{
    gListParticleNotes = [
        PSYS_SRC_PATTERN, PSYS_SRC_PATTERN_ANGLE_CONE,
        PSYS_SRC_BURST_RADIUS, 0.8,
        PSYS_SRC_ANGLE_BEGIN, 0.0,
        PSYS_SRC_ANGLE_END, 0.8,
        PSYS_PART_START_COLOR, <1.0, 0.9, 0.3>,
        PSYS_PART_END_COLOR, <1.0, 0.6, 0.1>,
        PSYS_PART_START_ALPHA, 0.9,
        PSYS_PART_END_ALPHA, 0.0,
        PSYS_PART_START_SCALE, <0.35, 0.35, 0.0>,
        PSYS_PART_END_SCALE, <0.05, 0.05, 0.0>,
        PSYS_PART_MAX_AGE, 2.5,
        PSYS_SRC_ACCEL, <0.0, 0.0, 0.8>,
        PSYS_SRC_BURST_PART_COUNT, 6,
        PSYS_SRC_BURST_RATE, 0.4,
        PSYS_SRC_BURST_SPEED_MIN, 0.6,
        PSYS_SRC_BURST_SPEED_MAX, 1.8,
        PSYS_SRC_OMEGA, <0.0, 0.0, 1.0>,
        PSYS_SRC_TEXTURE, pStrTexture,
        PSYS_PART_FLAGS, PSYS_PART_INTERP_COLOR_MASK | PSYS_PART_INTERP_SCALE_MASK | PSYS_PART_FOLLOW_SRC_MASK
    ];
}

stopParticles()
{
    llParticleSystem([]);
    gIntParticleTimerActive = FALSE;
}

// --- FUNÇÕES DE NEGÓCIO ---

sendScannerStatus()
{
    integer pIntTotal = llGetListLength(gListNearbyAvatars) / 3;
    string pStrStatus = "📡 Scanner ATIVO (360°)\nRaio: " + (string)SCAN_RANGE + "m\nAvatares proximos: " + (string)pIntTotal;

    if (pIntTotal > 0)
    {
        pStrStatus = pStrStatus + "\n\nDetectados:";
        integer pIntIdx;
        for (pIntIdx = 0; pIntIdx < llGetListLength(gListNearbyAvatars); pIntIdx = pIntIdx + 3)
        {
            pStrStatus = pStrStatus + "\n• " + llList2String(gListNearbyAvatars, pIntIdx + 1);
        }
    }
    llInstantMessage(gKeyOwner, pStrStatus);
}

giveGift(key pKeyTarget)
{
    list pListItems = [];
    integer pIntCount = llGetInventoryNumber(INVENTORY_ALL);
    integer pIntIdx;
    for (pIntIdx = 0; pIntIdx < pIntCount; pIntIdx = pIntIdx + 1)
    {
        string pStrName = llGetInventoryName(INVENTORY_ALL, pIntIdx);
        integer pIntType = llGetInventoryType(pStrName);
        if (pIntType != INVENTORY_SCRIPT && pStrName != gStrTranslationsNc)
        {
            pListItems = pListItems + [pStrName];
        }
    }
    if (llGetListLength(pListItems) > 0)
    {
        llGiveInventoryList(pKeyTarget, gStrFolderName, pListItems);
    }
}

default
{
    state_entry()
    {
        llSetPayPrice(PAY_HIDE, [100 ,200, 250, 300]);
        gKeyOwner = llGetOwner();
        llSetObjectName(gStrObjectName);
        llSetText("Iniciando sistema...", <1.0, 1.0, 1.0>, 1.0);

        initParticleSystem(TEXTURE_NOTE);

        gIntSensorActive = TRUE;
        llSensorRepeat("", NULL_KEY, AGENT, SCAN_RANGE, SCAN_ARC, SCAN_INTERVAL);

        llMessageLinked(LINK_THIS, LINK_RESET, "", NULL_KEY);

        if (gIntDebug) llOwnerSay("Tip Jar v5.7 iniciado.");
    }

    on_rez(integer pIntParam)
    {
        llResetScript();
    }

    changed(integer eIntChange)
    {
        if (eIntChange & CHANGED_OWNER) llResetScript();
    }

    money(key eKeySender, integer eIntAmount)
    {
        if (eIntAmount <= 0) return;

        string pStrName = llKey2Name(eKeySender);
        sendTranslatedIM(eKeySender, "THANK_YOU_TIP", ["NAME", pStrName, "AMOUNT", (string)eIntAmount]);
        llOwnerSay(pStrName + " contribuiu com L$" + (string)eIntAmount);

        stopParticles();
        llParticleSystem(gListParticleNotes);
        gIntTimerMode = TIMER_PARTICLES;
        llSetTimerEvent(5.0);

        giveGift(eKeySender);
    }

    touch_start(integer eIntTotal)
    {
        key pKeyToucher = llDetectedKey(0);
        if (pKeyToucher == gKeyOwner)
        {
            showMenu(pKeyToucher);
        }
        else
        {
            sendTranslatedIM(pKeyToucher, "WELCOME_TIP", []);
        }
    }

    sensor(integer eIntNum)
    {
        gListNearbyAvatars = [];
        integer pIntIdx;
        for (pIntIdx = 0; pIntIdx < eIntNum; pIntIdx = pIntIdx + 1)
        {
            gListNearbyAvatars = gListNearbyAvatars + [llDetectedKey(pIntIdx), llDetectedName(pIntIdx), llGetAgentLanguage(llDetectedKey(pIntIdx))];
        }

        if (gIntStatusRequested)
        {
            gIntStatusRequested = FALSE;
            sendScannerStatus();
        }

        if (gIntTranslationsReady) refreshFloatingText();
    }

    no_sensor()
    {
        gListNearbyAvatars = [];
        if (gIntStatusRequested)
        {
            gIntStatusRequested = FALSE;
            sendScannerStatus();
        }

        if (!gIntNoAvatars)
        {
            gIntNoAvatars = TRUE;
            gIntTextState = 0;
            llSetText(gStrDefaultEnglishMsg, <1.0, 1.0, 1.0>, 1.0);
            llSetTimerEvent(0.0);
        }
    }

    timer()
    {
        if (gIntTimerMode == TIMER_FADE)
        {
            updateFade();
        }
        else if (gIntTimerMode == TIMER_DISPLAY)
        {
            startFadeOut();
        }
        else if (gIntTimerMode == TIMER_MENU)
        {
            sendTranslatedIM(gKeyOwner, "MENU_TIMEOUT_MSG", []);
            cleanupMenu();
        }
        else if (gIntTimerMode == TIMER_PARTICLES)
        {
            stopParticles();
            llSetTimerEvent(0.0);
        }
    }

    link_message(integer eIntSender, integer eIntNum, string eStrMsg, key eKeyId)
    {
        if (eIntNum == LINK_MENU_RET && eKeyId == gKeyOwner)
        {
            list pListParts = llParseStringKeepNulls(eStrMsg, ["|"], []);
            string pStrTitle = llList2String(pListParts, 0);
            list pListButtons = llCSV2List(llList2String(pListParts, 1));
            llDialog(eKeyId, pStrTitle, pListButtons, gIntChannel);
        }
        else if (eIntNum == LINK_FLOAT_RET)
        {
            startFadeIn(eStrMsg);
        }
        else if (eIntNum == LINK_LOAD_DONE)
        {
            gIntTranslationsReady = TRUE;
            refreshFloatingText();
        }
        else if (eIntNum == LINK_CMD_RESULT && eKeyId == gKeyOwner)
        {
            string pStrCmd = eStrMsg;
            if (pStrCmd == "MENU_TEST_PARTICLES")
            {
                stopParticles();
                llParticleSystem(gListParticleNotes);
                gIntTimerMode = TIMER_PARTICLES;
                llSetTimerEvent(5.0);
                sendTranslatedIM(gKeyOwner, "PARTICLE_TEST_MSG", []);
            }
            else if (pStrCmd == "MENU_STOP_PARTICLES")
            {
                stopParticles();
                sendTranslatedIM(gKeyOwner, "PARTICLE_STOP_MSG", []);
            }
            else if (pStrCmd == "MENU_CHANGE_TEXTURE")
            {
                gIntCurrentTexture = (gIntCurrentTexture + 1) % 4;
                string pStrTex = TEXTURE_NOTE;
                string pStrMsgId = "TEXTURE_CHANGE_NOTE";
                if (gIntCurrentTexture == 1) { pStrTex = TEXTURE_STAR; pStrMsgId = "TEXTURE_CHANGE_STAR"; }
                else if (gIntCurrentTexture == 2) { pStrTex = TEXTURE_HEART; pStrMsgId = "TEXTURE_CHANGE_HEART"; }
                else if (gIntCurrentTexture == 3) { pStrTex = TEXTURE_GLOW; pStrMsgId = "TEXTURE_CHANGE_GLOW"; }
                initParticleSystem(pStrTex);
                stopParticles();
                llParticleSystem(gListParticleNotes);
                gIntTimerMode = TIMER_PARTICLES;
                llSetTimerEvent(3.0);
                sendTranslatedIM(gKeyOwner, pStrMsgId, []);
                sendTranslatedIM(gKeyOwner, "TEXTURE_TESTING_MSG", []);
            }
            else if (pStrCmd == "MENU_SCANNER_STATUS")
            {
                gIntStatusRequested = TRUE;
                llSensor("", NULL_KEY, AGENT, SCAN_RANGE, SCAN_ARC);
            }
            else if (pStrCmd == "MENU_HELP")
            {
                sendTranslatedIM(gKeyOwner, "HELP_MESSAGE", []);
            }
            else if (pStrCmd == "MENU_CANCEL")
            {
                sendTranslatedIM(gKeyOwner, "TEXT_CANCELLED", []);
            }
            cleanupMenu();
        }
    }

    listen(integer eIntChan, string eStrName, key eKeyId, string eStrMsg)
    {
        if (eIntChan == gIntChannel && eKeyId == gKeyOwner)
        {
            llMessageLinked(LINK_THIS, LINK_IDENTIFY_CMD, eStrMsg, eKeyId);
        }
    }
}
